{% extends 'base.html.twig' %}

{% block title %}Accueil - Stubborn{% endblock %}

{% block body %}
    {# Produits mis en avant #}
    <div class="row g-4 mb-5">
        {% for product in featured_products %}
            <div class="col-md-4">
                <div class="product-card rounded p-3 h-100">
                    <img src="{{ asset('images/products/' ~ product.image) }}"
                         alt="{{ product.name }}" class="rounded mb-3">
                    <h5>{{ product.name }}</h5>
                    <p class="text-muted">{{ product.price }} €</p>
                    {% if app.user %}
                        <a href="{{ path('app_product', {id: product.id}) }}"
                           class="btn btn-stubborn btn-sm">Voir</a>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </div>

    {# Présentation de la société #}
    <div class="row justify-content-center mt-4">
        <div class="col-md-8 text-center">
            <h2 class="mb-3">À propos de Stubborn</h2>
            <p class="lead text-muted">
                Stubborn est une marque londonienne de sweat-shirts qui croit fermement qu'on ne
                devrait jamais faire de compromis sur son style. Fondée à Piccadilly Circus,
                au cœur de Londres, notre marque propose des collections qui allient confort,
                qualité et originalité.
            </p>
            <p class="text-muted">
                Chaque pièce est conçue pour durer et affirmer votre personnalité.
                <strong>Don't compromise on your look.</strong>
            </p>
            {% if not app.user %}
                <a href="{{ path('app_register') }}" class="btn btn-stubborn me-2">Créer un compte</a>
                <a href="{{ path('app_login') }}" class="btn btn-outline-dark">Se connecter</a>
            {% else %}
                <a href="{{ path('app_products') }}" class="btn btn-stubborn">Voir la boutique</a>
            {% endif %}
        </div>
    </div>
{% endblock %}
