{% extends 'base.html.twig' %}

{% block title %}Back-Office - Stubborn{% endblock %}

{% block body %}
<div class="d-flex align-items-center mb-4">
    <h2 class="me-3 mb-0">Back-Office</h2>
    <span class="badge bg-dark">Administration</span>
</div>

{# ── Formulaire d'ajout ────────────────────────────────────────── #}
<div class="card mb-4 border-danger">
    <div class="card-header bg-danger text-white fw-bold">Ajouter un sweat-shirt</div>
    <div class="card-body">
        {{ form_start(add_form, {'attr': {'enctype': 'multipart/form-data', 'novalidate': 'novalidate'}}) }}
        <div class="row g-2 align-items-end">
            <div class="col-md-2">
                {{ form_label(add_form.name) }}
                {{ form_widget(add_form.name) }}
            </div>
            <div class="col-md-1">
                {{ form_label(add_form.price) }}
                {{ form_widget(add_form.price) }}
            </div>
            <div class="col-md-1">
                {{ form_label(add_form.stockXs) }}
                {{ form_widget(add_form.stockXs) }}
            </div>
            <div class="col-md-1">
                {{ form_label(add_form.stockS) }}
                {{ form_widget(add_form.stockS) }}
            </div>
            <div class="col-md-1">
                {{ form_label(add_form.stockM) }}
                {{ form_widget(add_form.stockM) }}
            </div>
            <div class="col-md-1">
                {{ form_label(add_form.stockL) }}
                {{ form_widget(add_form.stockL) }}
            </div>
            <div class="col-md-1">
                {{ form_label(add_form.stockXl) }}
                {{ form_widget(add_form.stockXl) }}
            </div>
            <div class="col-md-2">
                {{ form_label(add_form.imageFile) }}
                {{ form_widget(add_form.imageFile) }}
            </div>
            <div class="col-md-1 d-flex align-items-center gap-2 mt-3">
                {{ form_widget(add_form.featured) }}
                {{ form_label(add_form.featured) }}
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-danger w-100">Ajouter</button>
            </div>
        </div>
        {{ form_errors(add_form) }}
        {{ form_end(add_form) }}
    </div>
</div>

{# ── Liste des produits ────────────────────────────────────────── #}
{% for product in products %}
<div class="card mb-3">
    <div class="card-body">
        <form method="post"
              action="{{ path('app_admin_edit', {id: product.id}) }}"
              enctype="multipart/form-data">
            <div class="row g-2 align-items-center">
                {# Image #}
                <div class="col-md-1">
                    <img src="{{ asset('images/products/' ~ product.image) }}"
                         alt="{{ product.name }}"
                         class="img-fluid rounded" style="max-height: 70px; object-fit: cover;">
                </div>

                {# Champs du formulaire d'édition #}
                <div class="col-md-2">
                    <label class="form-label small">Nom</label>
                    <input type="text" name="product_form[name]" value="{{ product.name }}"
                           class="form-control form-control-sm" required>
                </div>
                <div class="col-md-1">
                    <label class="form-label small">Prix</label>
                    <input type="number" step="0.01" name="product_form[price]" value="{{ product.price }}"
                           class="form-control form-control-sm" required>
                </div>
                <div class="col-md-1">
                    <label class="form-label small">Stock XS</label>
                    <input type="number" name="product_form[stockXs]" value="{{ product.stockXs }}"
                           class="form-control form-control-sm" min="0">
                </div>
                <div class="col-md-1">
                    <label class="form-label small">Stock S</label>
                    <input type="number" name="product_form[stockS]" value="{{ product.stockS }}"
                           class="form-control form-control-sm" min="0">
                </div>
                <div class="col-md-1">
                    <label class="form-label small">Stock M</label>
                    <input type="number" name="product_form[stockM]" value="{{ product.stockM }}"
                           class="form-control form-control-sm" min="0">
                </div>
                <div class="col-md-1">
                    <label class="form-label small">Stock L</label>
                    <input type="number" name="product_form[stockL]" value="{{ product.stockL }}"
                           class="form-control form-control-sm" min="0">
                </div>
                <div class="col-md-1">
                    <label class="form-label small">Stock XL</label>
                    <input type="number" name="product_form[stockXl]" value="{{ product.stockXl }}"
                           class="form-control form-control-sm" min="0">
                </div>
                <div class="col-md-1">
                    <label class="form-label small">Image</label>
                    <input type="file" name="product_form[imageFile]" class="form-control form-control-sm">
                </div>
                <div class="col-md-1 text-center">
                    <label class="form-label small d-block">En avant</label>
                    <input type="checkbox" name="product_form[featured]" value="1"
                           class="form-check-input" style="width:1.2rem;height:1.2rem;"
                           {{ product.featured ? 'checked' : '' }}>
                </div>
                <div class="col-md-1 d-flex flex-column gap-1">
                    <input type="hidden" name="_token" value="{{ csrf_token('product_form') }}">
                    <button type="submit" class="btn btn-outline-dark btn-sm">Modifier</button>
                </div>
            </div>
        </form>

        {# Bouton supprimer séparé #}
        <form method="post" action="{{ path('app_admin_delete', {id: product.id}) }}" class="mt-2"
              onsubmit="return confirm('Supprimer « {{ product.name }} » ?')">
            <input type="hidden" name="_token" value="{{ csrf_token('delete_product_' ~ product.id) }}">
            <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
        </form>
    </div>
</div>
{% endfor %}
{% endblock %}
