{% extends 'base.html.twig' %}

{% block title %}{{ product.name }} - Stubborn{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card shadow-sm p-4">
            <div class="row align-items-center">
                {# Image #}
                <div class="col-md-6">
                    <img src="{{ asset('images/products/' ~ product.image) }}"
                         alt="{{ product.name }}"
                         class="img-fluid rounded"
                         style="max-height: 450px; object-fit: cover; width: 100%;">
                </div>

                {# Détails + formulaire #}
                <div class="col-md-6 ps-4">
                    <h4 class="mb-1">{{ product.name }}</h4>
                    <p class="text-muted fs-5 mb-4">{{ product.price }} €</p>

                    <form method="post" action="{{ path('app_cart_add', {id: product.id}) }}">
                        <div class="mb-4">
                            <label class="form-label fw-bold">Taille</label>
                            <select name="size" class="form-select" required>
                                <option value="" disabled selected>Sélectionner une taille</option>
                                {% for size in sizes %}
                                    <option value="{{ size }}">{{ size }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <button type="submit" class="btn btn-stubborn w-100">
                            Ajouter au panier
                        </button>
                    </form>

                    <div class="mt-3">
                        <a href="{{ path('app_products') }}" class="text-muted small">← Retour à la boutique</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
