{% extends 'base.html.twig' %}

{% block title %}Boutique - Stubborn{% endblock %}

{% block body %}

{% if products is empty %}
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card p-3">
                <h6 class="fw-bold mb-3">Fourchette de prix</h6>
                <div class="list-group list-group-flush">
                    <a href="{{ path('app_products') }}"
                       class="list-group-item list-group-item-action {% if price_range is null %}active{% endif %}">
                        Tous les prix
                    </a>
                    <a href="{{ path('app_products', {price: '10-29'}) }}"
                       class="list-group-item list-group-item-action {% if price_range == '10-29' %}active{% endif %}">
                        10 à 29 €
                    </a>
                    <a href="{{ path('app_products', {price: '29-35'}) }}"
                       class="list-group-item list-group-item-action {% if price_range == '29-35' %}active{% endif %}">
                        29 à 35 €
                    </a>
                    <a href="{{ path('app_products', {price: '35-50'}) }}"
                       class="list-group-item list-group-item-action {% if price_range == '35-50' %}active{% endif %}">
                        35 à 50 €
                    </a>
                </div>
            </div>
            <div class="mt-3">
                <a href="{{ path('app_home') }}" class="text-muted small">← Retour à l'accueil</a>
            </div>
        </div>
        <div class="col-md-9">
            <p class="text-muted">Aucun produit dans cette fourchette de prix.</p>
        </div>
    </div>

{% else %}

    {# ── Ligne 1 : sidebar + 2 premiers produits ── #}
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card p-3">
                <h6 class="fw-bold mb-3">Fourchette de prix</h6>
                <div class="list-group list-group-flush">
                    <a href="{{ path('app_products') }}"
                       class="list-group-item list-group-item-action {% if price_range is null %}active{% endif %}">
                        Tous les prix
                    </a>
                    <a href="{{ path('app_products', {price: '10-29'}) }}"
                       class="list-group-item list-group-item-action {% if price_range == '10-29' %}active{% endif %}">
                        10 à 29 €
                    </a>
                    <a href="{{ path('app_products', {price: '29-35'}) }}"
                       class="list-group-item list-group-item-action {% if price_range == '29-35' %}active{% endif %}">
                        29 à 35 €
                    </a>
                    <a href="{{ path('app_products', {price: '35-50'}) }}"
                       class="list-group-item list-group-item-action {% if price_range == '35-50' %}active{% endif %}">
                        35 à 50 €
                    </a>
                </div>
            </div>
            <div class="mt-3">
                <a href="{{ path('app_home') }}" class="text-muted small">← Retour à l'accueil</a>
            </div>
        </div>

        {% for product in products|slice(0, 2) %}
            <div class="col-md-4">
                <div class="product-card rounded p-3 h-100">
                    <img src="{{ asset('images/products/' ~ product.image) }}"
                         alt="{{ product.name }}" class="rounded mb-3">
                    <h6>{{ product.name }}</h6>
                    <div class="d-flex justify-content-between align-items-center">
                        <p class="text-muted mb-0">{{ product.price }} €</p>
                        <a href="{{ path('app_product', {id: product.id}) }}"
                           class="btn btn-stubborn btn-sm">Voir</a>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    {# ── Lignes suivantes : 3 produits par ligne ── #}
    {% if products|length > 2 %}
        <div class="row g-4">
            {% for product in products|slice(2) %}
                <div class="col-md-4">
                    <div class="product-card rounded p-3 h-100">
                        <img src="{{ asset('images/products/' ~ product.image) }}"
                             alt="{{ product.name }}" class="rounded mb-3">
                        <h6>{{ product.name }}</h6>
                        <div class="d-flex justify-content-between align-items-center">
                            <p class="text-muted mb-0">{{ product.price }} €</p>
                            <a href="{{ path('app_product', {id: product.id}) }}"
                               class="btn btn-stubborn btn-sm">Voir</a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

{% endif %}

{% endblock %}
